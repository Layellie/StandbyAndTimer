# EditorConfig — keeps formatting consistent across editors/checkouts.
# See https://editorconfig.org for the spec.

root = true

[*]
charset                  = utf-8
end_of_line              = crlf
indent_style             = space
insert_final_newline     = true
trim_trailing_whitespace = true

[*.{cs,xaml}]
indent_size = 4

[*.{json,yml,yaml,xml,csproj,props,targets,pubxml,iss}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false   # markdown line-breaks need trailing spaces

# C# style — only the bits we want to enforce as warnings.
[*.cs]
# var: prefer explicit type for built-ins, var for everything else.
dotnet_style_predefined_type_for_locals_parameters_members = true:silent
dotnet_style_predefined_type_for_member_access             = true:silent

# Modern language features.
csharp_style_var_for_built_in_types         = false:suggestion
csharp_style_var_when_type_is_apparent      = true:suggestion
csharp_style_var_elsewhere                  = false:silent
csharp_style_expression_bodied_methods      = when_on_single_line:suggestion
csharp_style_pattern_matching_over_is_with_cast_check     = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check     = true:suggestion
csharp_style_prefer_switch_expression       = true:suggestion
csharp_style_namespace_declarations         = file_scoped:warning

# Using directives placement.
csharp_using_directive_placement            = outside_namespace:warning
