<UserControl x:Class="StandbyAndTimer.Views.SettingsPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:StandbyAndTimer.Views.Converters"
             FontFamily="Segoe UI" FontSize="13">

    <UserControl.Resources>
        <conv:LanguageDisplayConverter x:Key="LangConv"/>
        <conv:ThemeDisplayConverter    x:Key="ThemeConv"/>
        <BooleanToVisibilityConverter  x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="18,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0  Header -->
            <RowDefinition Height="20"/>    <!-- 1 -->
            <RowDefinition Height="Auto"/>  <!-- 2  AutoStart -->
            <RowDefinition Height="12"/>    <!-- 3 -->
            <RowDefinition Height="Auto"/>  <!-- 4  UpdateCheck -->
            <RowDefinition Height="20"/>    <!-- 5 -->
            <RowDefinition Height="Auto"/>  <!-- 6  Language label -->
            <RowDefinition Height="8"/>     <!-- 7 -->
            <RowDefinition Height="Auto"/>  <!-- 8  Language picker -->
            <RowDefinition Height="14"/>    <!-- 9 -->
            <RowDefinition Height="Auto"/>  <!-- 10 Theme label -->
            <RowDefinition Height="8"/>     <!-- 11 -->
            <RowDefinition Height="Auto"/>  <!-- 12 Theme picker -->
            <RowDefinition Height="22"/>    <!-- 13 -->
            <RowDefinition Height="Auto"/>  <!-- 14 Backup section label -->
            <RowDefinition Height="8"/>     <!-- 15 -->
            <RowDefinition Height="Auto"/>  <!-- 16 Export -->
            <RowDefinition Height="6"/>     <!-- 17 -->
            <RowDefinition Height="Auto"/>  <!-- 18 Import -->
            <RowDefinition Height="6"/>     <!-- 19 -->
            <RowDefinition Height="Auto"/>  <!-- 20 Check Update -->
            <RowDefinition Height="6"/>     <!-- 21 -->
            <RowDefinition Height="Auto"/>  <!-- 22 Open Log -->
            <RowDefinition Height="14"/>    <!-- 23 -->
            <RowDefinition Height="Auto"/>  <!-- 24 Update status text -->
            <RowDefinition Height="*"/>     <!-- 25 spacer -->
            <RowDefinition Height="Auto"/>  <!-- 26 Version footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <TextBlock Text="{DynamicResource Str_Settings_Title}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppFg}"
                       VerticalAlignment="Center"/>
            <Button Content="{DynamicResource Str_Settings_Close}"
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    HorizontalAlignment="Right"
                    Width="26" Height="26"/>
        </Grid>

        <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                Background="{DynamicResource SeparatorBrush}"
                Margin="0,26,0,-6"/>

        <!-- ── Launch on Startup ────────────────────────────────────────────── -->
        <CheckBox Grid.Row="2"
                  Content="{DynamicResource Str_Settings_LaunchOnStartup}"
                  IsChecked="{Binding AutoStartEnabled}"
                  Style="{StaticResource DarkCheckBoxStyle}"/>

        <!-- ── Update check on startup ──────────────────────────────────────── -->
        <CheckBox Grid.Row="4"
                  Content="{DynamicResource Str_Settings_CheckUpdate}"
                  IsChecked="{Binding UpdateCheckEnabled}"
                  Style="{StaticResource DarkCheckBoxStyle}"/>

        <!-- ── Language label ───────────────────────────────────────────────── -->
        <TextBlock Grid.Row="6"
                   Text="{DynamicResource Str_Settings_Language}"
                   Foreground="{DynamicResource AppFgDim}"
                   FontSize="11" FontWeight="SemiBold"/>

        <ComboBox Grid.Row="8"
                  ItemsSource="{Binding LanguageOptions}"
                  SelectedItem="{Binding SelectedLanguage}"
                  Style="{StaticResource SettingsComboBoxStyle}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource LangConv}}"
                               Foreground="{DynamicResource InputFg}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- ── Theme label ──────────────────────────────────────────────────── -->
        <TextBlock Grid.Row="10"
                   Text="{DynamicResource Str_Settings_Theme}"
                   Foreground="{DynamicResource AppFgDim}"
                   FontSize="11" FontWeight="SemiBold"/>

        <ComboBox Grid.Row="12"
                  ItemsSource="{Binding ThemeOptions}"
                  SelectedItem="{Binding SelectedTheme}"
                  Style="{StaticResource SettingsComboBoxStyle}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource ThemeConv}}"
                               Foreground="{DynamicResource InputFg}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- ── Backup & Maintenance ─────────────────────────────────────────── -->
        <TextBlock Grid.Row="14"
                   Text="{DynamicResource Str_Settings_BackupSection}"
                   Foreground="{DynamicResource AppFgDim}"
                   FontSize="11" FontWeight="SemiBold"/>

        <Button Grid.Row="16"
                Content="{DynamicResource Str_Settings_Export}"
                Command="{Binding ExportSettingsCommand}"
                Style="{StaticResource GhostButtonStyle}"
                Height="28"
                HorizontalAlignment="Stretch"/>

        <Button Grid.Row="18"
                Content="{DynamicResource Str_Settings_Import}"
                Command="{Binding ImportSettingsCommand}"
                Style="{StaticResource GhostButtonStyle}"
                Height="28"
                HorizontalAlignment="Stretch"/>

        <StackPanel Grid.Row="20" Orientation="Vertical">
            <Button Content="{DynamicResource Str_Settings_CheckUpdate}"
                    Command="{Binding CheckUpdateCommand}"
                    Style="{StaticResource DarkButtonStyle}"
                    Height="28"
                    HorizontalAlignment="Stretch"/>
            <Button Content="{DynamicResource Str_Settings_DownloadInstall}"
                    Command="{Binding DownloadAndInstallCommand}"
                    Style="{StaticResource DarkButtonStyle}"
                    Height="28"
                    Margin="0,6,0,0"
                    HorizontalAlignment="Stretch"
                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <Button Grid.Row="22"
                Content="{DynamicResource Str_Settings_OpenLog}"
                Command="{Binding OpenLogFolderCommand}"
                Style="{StaticResource GhostButtonStyle}"
                Height="28"
                HorizontalAlignment="Stretch"/>

        <TextBlock Grid.Row="24"
                   Text="{Binding UpdateStatus}"
                   Foreground="{DynamicResource AppFgDim}"
                   TextWrapping="Wrap"
                   FontSize="11"/>

        <!-- ── Version footer ──────────────────────────────────────────────────
             Pinned to the bottom of the panel — Row 25 is the * spacer that
             pushes this label down regardless of how many rows above grow.
             The "v" prefix matches the GitHub release tag format (v2.0.5)
             so what the user sees here is the same string they'd see on the
             release page. CurrentVersion is computed from the assembly so it
             auto-updates with every -p:Version=X.Y.Z release build. -->
        <TextBlock Grid.Row="26"
                   Text="{Binding CurrentVersion, StringFormat=v{0}}"
                   Foreground="{DynamicResource AppFgDim}"
                   FontSize="10.5"
                   Opacity="0.7"
                   HorizontalAlignment="Right"
                   Margin="0,0,0,2"/>

    </Grid>
</UserControl>
