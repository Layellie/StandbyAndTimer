<Window x:Class="StandbyAndTimer.Views.CrashReporterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StandbyAndTimer"
        Width="560" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource AppFg}"
        FontFamily="Segoe UI" FontSize="13"
        Icon="/app_icon.ico"
        Topmost="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Ellipse Width="10" Height="10" Fill="#E84A4A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="{DynamicResource Str_Crash_Title}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppFg}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Text="{DynamicResource Str_Crash_Body}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource AppFgDim}"
                       FontSize="12"
                       Margin="0,0,0,12"/>

            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceBg}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10"
                    Margin="0,0,0,12">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="DetailsBox"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="{DynamicResource AppFgDim}"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="11"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"/>
                </ScrollViewer>
            </Border>

            <TextBlock Grid.Row="3"
                       x:Name="StatusText"
                       Text=""
                       Foreground="{DynamicResource SuccessColor}"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       Margin="0,0,0,8"/>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Content="{DynamicResource Str_Crash_CopyDetails}"
                        Style="{StaticResource GhostButtonStyle}"
                        Height="30" MinWidth="120"
                        Click="OnCopyClick"/>
                <Button Grid.Column="2"
                        Content="{DynamicResource Str_Crash_OpenIssue}"
                        Style="{StaticResource DarkButtonStyle}"
                        Height="30" MinWidth="140"
                        Margin="8,0,0,0"
                        Click="OnOpenIssueClick"/>
                <Button Grid.Column="3"
                        Content="{DynamicResource Str_Crash_Close}"
                        Style="{StaticResource GhostButtonStyle}"
                        Height="30" MinWidth="80"
                        Margin="8,0,0,0"
                        Click="OnCloseClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
