<UserControl x:Class="StandbyAndTimer.Views.Cards.MemoryStatsCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:StandbyAndTimer.Views.Converters"
             FontFamily="Segoe UI" FontSize="13">
    <UserControl.Resources>
        <conv:MbToGbConverter x:Key="MbToGbConv"/>
    </UserControl.Resources>

    <!-- Standby memory KPI + total / free split below. Binds to StandbyRamMb /
         TotalRamMb / FreeRamMb on MainViewModel.

         Three-row Grid (Auto / * / Auto): title pinned top, KPI vertically
         centered in the slack, Total/Free strip pinned to the bottom. The
         middle * row absorbs whatever extra height the sibling StandbyPurge
         card forces on this row, so the box never has a dead band at the
         bottom — content is distributed evenly through the full cell. -->
    <Border Style="{StaticResource SectionBorderStyle}"
            Padding="16,14"
            Margin="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0 Title -->
                <RowDefinition Height="*"/>     <!-- 1 KPI block (centered) -->
                <RowDefinition Height="Auto"/>  <!-- 2 Total / Free strip -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{DynamicResource Str_Card_StandbyTitle}"
                       Style="{StaticResource SectionLabelStyle}"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding StandbyRamMb, Converter={StaticResource MbToGbConv}}"
                               Style="{StaticResource KpiValueStyle}"/>
                    <TextBlock Text="GB"
                               FontSize="13"
                               VerticalAlignment="Bottom"
                               Margin="5,0,0,5"
                               Foreground="{DynamicResource AppFgDim}"/>
                </StackPanel>

                <TextBlock Text="{DynamicResource Str_Card_StandbyClearable}"
                           FontSize="12"
                           Foreground="{DynamicResource AppFgDim}"
                           Margin="0,3,0,0"/>
            </StackPanel>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource SeparatorBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource Str_Memory_TotalShort}"
                                   FontSize="10"
                                   Foreground="{DynamicResource AppFgDim}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding TotalRamMb, StringFormat={}{0} MB}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{DynamicResource Str_Memory_FreeShort}"
                                   FontSize="10"
                                   Foreground="{DynamicResource AppFgDim}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding FreeRamMb, StringFormat={}{0} MB}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessColor}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource Str_Memory_PurgesShort}"
                                   FontSize="10"
                                   Foreground="{DynamicResource AppFgDim}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding PurgeCount}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppFg}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
