<UserControl x:Class="StandbyAndTimer.Views.Cards.TimerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="13">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <!-- Hero card — actual timer resolution + toggle button. Binds to
         TimerActive / ActualTimerMs / TimerButtonLabel / ToggleTimerResolutionCommand
         on MainViewModel. -->
    <Border Style="{StaticResource SectionBorderStyle}" Padding="18,14">
        <StackPanel>
            <!-- MinHeight reserves the badge's vertical footprint so toggling
                 the timer ON doesn't grow the title row by a few px and shift
                 the value/button row below it. Without this, every Timer
                 toggle made the card "breathe" by ~6 px. -->
            <Grid Margin="0,0,0,4" MinHeight="24">
                <TextBlock Text="{DynamicResource Str_Card_TimerTitle}"
                           Style="{StaticResource SectionLabelStyle}"
                           VerticalAlignment="Center"/>
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource SuccessBadgeStyle}"
                        Visibility="{Binding TimerActive, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M5,0 L5,3 L9,3 L9,8 L1,8 L1,3 L5,3 M3,3 L3,1.5 A2,2 0 0 1 7,1.5 L7,3"
                              Stroke="{DynamicResource SuccessColor}"
                              StrokeThickness="1"
                              Width="10" Height="9"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Margin="0,0,5,0"/>
                        <TextBlock Text="{DynamicResource Str_Card_TimerLocked}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessColor}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding ActualTimerMs, StringFormat={}{0:F2}}"
                               Style="{StaticResource HeroValueStyle}"/>
                    <TextBlock Text="ms"
                               FontSize="18"
                               FontWeight="Light"
                               Foreground="{DynamicResource AppFgDim}"
                               VerticalAlignment="Bottom"
                               Margin="6,0,0,12"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="{Binding TimerButtonLabel}"
                        Command="{Binding ToggleTimerResolutionCommand}"
                        Style="{StaticResource DarkButtonStyle}"
                        MinWidth="120" Height="38"
                        VerticalAlignment="Center"
                        FontSize="13"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
