<UserControl x:Class="StandbyAndTimer.Views.Cards.StandbyPurgeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="13">

    <!-- Purge controls: count, AUTO PURGE master toggle, two thresholds, and
         the manual purge button. Binds to PurgeCount / AutoPurgeEnabled /
         StandbyLimitMb / FreeLimitMb / ManualPurgeCommand on MainViewModel. -->
    <Border Style="{StaticResource SectionBorderStyle}"
            Padding="16,14"
            Margin="0">
        <StackPanel>
            <TextBlock Text="{DynamicResource Str_Card_PurgeTitle}"
                       Style="{StaticResource SectionLabelStyle}"
                       Margin="0,0,0,8"/>

            <!-- AUTO PURGE master toggle — when off, both thresholds are
                 ignored and no automatic purge ever fires. -->
            <Grid Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource Str_Card_AutoPurgeLabel}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppFgDim}"
                           VerticalAlignment="Center"/>
                <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                          IsChecked="{Binding AutoPurgeEnabled}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center">
                    <CheckBox.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{DynamicResource Str_Card_GameModeOff}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AutoPurgeEnabled}" Value="True">
                                            <Setter Property="Text" Value="{DynamicResource Str_Card_GameModeOn}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </CheckBox.Content>
                </CheckBox>
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="78"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource Str_Purge_StandbyLimitLabel}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppFgDim}"
                           Margin="0,0,6,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding StandbyLimitMb, UpdateSourceTrigger=LostFocus}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Height="26" FontSize="12"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="78"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource Str_Purge_FreeLimitLabel}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppFgDim}"
                           Margin="0,0,6,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding FreeLimitMb, UpdateSourceTrigger=LostFocus}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Height="26" FontSize="12"/>
            </Grid>

            <Button Content="{DynamicResource Str_Purge_Button}"
                    Command="{Binding ManualPurgeCommand}"
                    Style="{StaticResource DarkButtonStyle}"
                    Height="32"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Border>
</UserControl>
