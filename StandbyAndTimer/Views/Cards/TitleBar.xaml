<UserControl x:Class="StandbyAndTimer.Views.Cards.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             FontFamily="Segoe UI" FontSize="13">

    <!-- Custom title bar — the window has WindowStyle=None, so we render
         caption, app name, admin badge, and Settings/About/Minimize/Close
         buttons ourselves. shell:WindowChrome on MainWindow makes the bar
         draggable; the action buttons opt out via IsHitTestVisibleInChrome. -->
    <Border Background="{DynamicResource SurfaceBg}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="0,0,0,1"
            Height="36">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: status dot + app name -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center">
                <Ellipse Width="9" Height="9"
                         Fill="{DynamicResource SuccessColor}"
                         VerticalAlignment="Center"
                         Margin="0,0,9,0"/>
                <TextBlock Text="StandbyAndTimer"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppFg}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Right: admin badge + window controls -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">

                <Border Style="{StaticResource SuccessBadgeStyle}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M5,0 L5,3 L9,3 L9,8 L1,8 L1,3 L5,3 M3,3 L3,1.5 A2,2 0 0 1 7,1.5 L7,3"
                              Stroke="{DynamicResource SuccessColor}"
                              StrokeThickness="1"
                              Width="10" Height="9"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Margin="0,0,5,0"/>
                        <TextBlock Text="{DynamicResource Str_TitleBar_Admin}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessColor}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Style="{StaticResource TitleBarIconButtonStyle}"
                        Content="⚙"
                        FontSize="14"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip="Settings"/>

                <Button Style="{StaticResource TitleBarIconButtonStyle}"
                        Content="?"
                        FontSize="13"
                        Command="{Binding ShowAboutCommand}"
                        ToolTip="About"/>

                <Button Style="{StaticResource TitleBarIconButtonStyle}"
                        Content="—"
                        FontSize="11"
                        Click="OnMinimizeClick"
                        ToolTip="Minimize"/>

                <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                        Content="✕"
                        FontSize="12"
                        Click="OnCloseClick"
                        ToolTip="Close"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
