    <sys:String x:Key="Str_Purge_FreeLimitLabel">Serbest bellek altında (MB):</sys:String>
    <sys:String x:Key="Str_Purge_Button">Standby Temizle</sys:String>

    <!-- Oyun modu -->
    <sys:String x:Key="Str_Game_Mode">OYUN MODU</sys:String>
