    <sys:String x:Key="Str_Tray_TimerDisable">Timer'ı Kapat</sys:String>
    <sys:String x:Key="Str_Tray_PurgeNow">Standby'ı Temizle</sys:String>
    <sys:String x:Key="Str_Tray_Exit">Çıkış</sys:String>

    <!-- Tray balloon / tooltip -->
    <sys:String x:Key="Str_Tray_TooltipFormat">StandbyAndTimer&#x0a;Timer: {0}  •  Temizleme: {1}</sys:String>
    <sys:String x:Key="Str_Tray_TimerStateOn">AÇIK</sys:String>
    <sys:String x:Key="Str_Tray_TimerStateOff">KAPALI</sys:String>
    <sys:String x:Key="Str_Tray_NotifyPurgeTitle">Standby bellek temizlendi</sys:String>
    <sys:String x:Key="Str_Tray_NotifyPurgeBody">Toplam temizleme: {0}</sys:String>
    <sys:String x:Key="Str_Tray_NotifyTimerOnTitle">Timer aktif</sys:String>
    <sys:String x:Key="Str_Tray_NotifyTimerOnBody">Sistem saati {0:F3} ms olarak kilitlendi</sys:String>
    <sys:String x:Key="Str_Tray_NotifyTimerOffTitle">Timer devre dışı</sys:String>
    <sys:String x:Key="Str_Tray_NotifyTimerOffBody">Sistem saati varsayılana döndü</sys:String>

