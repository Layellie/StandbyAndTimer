    <sys:String x:Key="Str_Card_GameModeOff">Kapalı</sys:String>
    <sys:String x:Key="Str_Card_GameModeDesc">Yüksek öncelik · Tam affinity</sys:String>

    <!-- Temizleme bölümü -->
