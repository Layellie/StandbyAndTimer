    <sys:String x:Key="Str_Status_GameExists">Bu oyun zaten listede</sys:String>
    <sys:String x:Key="Str_Status_GameRemoved">Oyun kaldırıldı</sys:String>

    <!-- Hakkında penceresi -->
    <sys:String x:Key="Str_About_Title">Hakkında ve Kullanım Kılavuzu</sys:String>
    <sys:String x:Key="Str_About_Text">StandbyAndTimer — Sistem Optimizasyon Aracı&#x0a;&#x0a;1. Sistem timer'ını 0.5 ms'ye kilitler (NtSetTimerResolution)&#x0a;2. Standby bellek listesini otomatik/manuel temizler (NtSetSystemInformation)&#x0a;3. Oyunlar için Yüksek Öncelik + CPU Affinity ayarlar&#x0a;&#x0a;─── Önerilen Purge Eşikleri ───&#x0a;•  4 GB RAM → Liste: 512 MB  | Serbest: 512 MB&#x0a;•  8 GB RAM → Liste: 1024 MB | Serbest: 1024 MB&#x0a;• 16 GB RAM → Liste: 2048 MB | Serbest: 1024 MB&#x0a;• 32 GB RAM → Liste: 4096 MB | Serbest: 2048 MB&#x0a;• 64 GB RAM → Liste: 8192 MB | Serbest: 2048 MB&#x0a;&#x0a;Geliştirici: LAYE77IE</sys:String>
    <sys:String x:Key="Str_About_Close">Kapat</sys:String>

    <!-- Tek instance uyarısı -->
    <sys:String x:Key="Str_AlreadyRunning">Uygulama zaten arka planda çalışıyor.&#x0a;Sistem tepsisindeki simgeye bakın.</sys:String>

    <!-- Kapatma onay ekranı -->
    <sys:String x:Key="Str_Close_Title">Uygulamayı Kapat</sys:String>
    <sys:String x:Key="Str_Close_Message">Uygulama sistem tepsisinde çalışmaya devam edebilir ve sisteminizi optimize etmeyi sürdürebilir.</sys:String>
    <sys:String x:Key="Str_Close_Minimize">Arka Planda Çalıştır</sys:String>
    <sys:String x:Key="Str_Close_Exit">Tamamen Kapat</sys:String>

</ResourceDictionary>
