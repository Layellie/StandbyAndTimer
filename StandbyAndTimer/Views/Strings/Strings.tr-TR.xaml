    <sys:String x:Key="Str_About_Button">?</sys:String>
    <sys:String x:Key="Str_Settings_Button">⚙</sys:String>

    <!-- Ayarlar paneli -->
    <sys:String x:Key="Str_Settings_Title">AYARLAR</sys:String>
    <sys:String x:Key="Str_Settings_LaunchOnStartup">Başlangıçta Başlat (Simge Durumunda)</sys:String>
    <sys:String x:Key="Str_Settings_Language">Dil</sys:String>
    <sys:String x:Key="Str_Settings_Theme">Tema</sys:String>
    <sys:String x:Key="Str_Theme_Dark">Koyu</sys:String>
    <sys:String x:Key="Str_Theme_Light">Açık</sys:String>
    <sys:String x:Key="Str_Theme_System">Sistem</sys:String>
    <sys:String x:Key="Str_Settings_Close">✕</sys:String>
    <sys:String x:Key="Str_Settings_Export">Ayarları Dışa Aktar</sys:String>
    <sys:String x:Key="Str_Settings_Import">Ayarları İçe Aktar</sys:String>
    <sys:String x:Key="Str_Settings_CheckUpdate">Güncellemeleri Kontrol Et</sys:String>
    <sys:String x:Key="Str_Settings_UpdateAvailable">Yeni sürüm var: {0}</sys:String>
    <sys:String x:Key="Str_Settings_UpdateNone">En güncel sürümdesiniz</sys:String>
    <sys:String x:Key="Str_Settings_UpdateChecking">Kontrol ediliyor…</sys:String>
    <sys:String x:Key="Str_Settings_DownloadInstall">İndir ve Kur</sys:String>
    <sys:String x:Key="Str_Settings_Downloading">İndiriliyor… %{0}</sys:String>
    <sys:String x:Key="Str_Settings_LaunchingInstaller">Yükleyici başlatılıyor…</sys:String>
    <sys:String x:Key="Str_Settings_DownloadFailed">İndirme başarısız</sys:String>
    <sys:String x:Key="Str_Settings_ExportOk">Ayarlar dışa aktarıldı</sys:String>
    <sys:String x:Key="Str_Settings_ImportOk">Ayarlar yüklendi — uygulamayı yeniden başlatın</sys:String>
    <sys:String x:Key="Str_Settings_ImportFail">İçe aktarma başarısız</sys:String>
    <sys:String x:Key="Str_Settings_BackupSection">Yedekleme ve Bakım</sys:String>
    <sys:String x:Key="Str_Settings_OpenLog">Log Klasörünü Aç</sys:String>

    <!-- Dil isimleri -->
    <sys:String x:Key="Str_Lang_English">English</sys:String>
    <sys:String x:Key="Str_Lang_Turkish">Türkçe</sys:String>

    <!-- Tray menü -->
    <sys:String x:Key="Str_Tray_Show">Göster</sys:String>
