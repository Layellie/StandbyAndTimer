<UserControl x:Class="StandbyAndTimer.Views.Overlays.WizardOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="13">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <!-- Shown once on the very first launch. Click-to-dismiss outside the
         card is intentional — onboarding shouldn't trap a user who already
         knows the app. -->
    <Border Background="{DynamicResource ModalOverlayBrush}"
            Visibility="{Binding IsWizardVisible, Converter={StaticResource BoolToVis}}">
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="{Binding DismissWizardCommand}"/>
        </Border.InputBindings>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource Surface2Bg}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLarge}"
                Padding="24,20"
                MaxWidth="420">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Ellipse Width="9" Height="9"
                             Fill="{DynamicResource AccentPrimary}"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding WizardTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppFg}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="{Binding WizardBody}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppFgDim}"
                           FontSize="12"
                           LineHeight="18"
                           Margin="0,0,0,18"/>

                <Button Content="{Binding WizardFinish}"
                        Command="{Binding DismissWizardCommand}"
                        Style="{StaticResource DarkButtonStyle}"
                        HorizontalAlignment="Right"
                        MinWidth="100" Height="32"/>
            </StackPanel>
        </Border>
    </Border>
</UserControl>
