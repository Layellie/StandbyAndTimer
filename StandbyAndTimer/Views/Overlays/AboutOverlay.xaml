<UserControl x:Class="StandbyAndTimer.Views.Overlays.AboutOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="13">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource ModalOverlayBrush}"
            Visibility="{Binding IsAboutVisible, Converter={StaticResource BoolToVis}}">
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAboutCommand}"/>
        </Border.InputBindings>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource Surface2Bg}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLarge}"
                Padding="22,18"
                MaxWidth="380">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Ellipse Width="9" Height="9"
                             Fill="{DynamicResource AccentPrimary}"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding AboutTitle}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppFg}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="{Binding AboutText}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppFgDim}"
                           FontSize="11"
                           FontFamily="Consolas"
                           Margin="0,0,0,16"/>

                <Button Content="{Binding AboutClose}"
                        Command="{Binding CloseAboutCommand}"
                        Style="{StaticResource DarkButtonStyle}"
                        HorizontalAlignment="Right"
                        MinWidth="80" Height="30"/>
            </StackPanel>
        </Border>
    </Border>
</UserControl>
