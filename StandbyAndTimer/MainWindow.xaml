<Window x:Class="StandbyAndTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:StandbyAndTimer.Views"
        xmlns:conv="clr-namespace:StandbyAndTimer.Views.Converters"
        Title="StandbyAndTimer"
        Width="450"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource AppFg}"
        FontFamily="Segoe UI"
        FontSize="13" Icon="/app_icon.ico">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/Styles/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:GameIconConverter x:Key="GameIconConv"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Root grid: main content + dim overlay + settings panel + about overlay + close overlay -->
    <Grid x:Name="RootGrid" ClipToBounds="True">

        <!-- ── Main content ────────────────────────────────────────────────── -->
        <StackPanel Margin="14,14,14,10">

            <!-- ── Memory Stats ───────────────────────────────────────────── -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{DynamicResource Str_Memory_TotalLabel}"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding TotalRamMb, StringFormat='{}{0} MB'}"
                               FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentPrimary}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{DynamicResource Str_Memory_StandbyLabel}"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding StandbyRamMb, StringFormat='{}{0} MB'}"
                               FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center"
                               Foreground="{DynamicResource AppFgDim}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="{DynamicResource Str_Memory_FreeLabel}"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding FreeRamMb, StringFormat='{}{0} MB'}"
                               FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center"
                               Foreground="{DynamicResource SuccessColor}"/>
                </Grid>
            </Border>

            <!-- ── Standby Purge Settings ─────────────────────────────────── -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{DynamicResource Str_Purge_StandbyLimitLabel}"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding StandbyLimitMb, UpdateSourceTrigger=LostFocus}"
                             Style="{StaticResource InputTextBoxStyle}"
                             VerticalAlignment="Center" Height="26"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{DynamicResource Str_Purge_FreeLimitLabel}"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding FreeLimitMb, UpdateSourceTrigger=LostFocus}"
                             Style="{StaticResource InputTextBoxStyle}"
                             VerticalAlignment="Center" Height="26"/>

                    <Button Grid.Row="2" Grid.Column="0"
                            Content="{DynamicResource Str_Purge_Button}"
                            Command="{Binding ManualPurgeCommand}"
                            Style="{StaticResource DarkButtonStyle}"
                            HorizontalAlignment="Left"
                            MinWidth="140" Height="28"/>

                    <StackPanel Grid.Row="2" Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="×" Foreground="{DynamicResource AppFgDim}" FontSize="12"/>
                        <TextBlock Text="{Binding PurgeCount}"
                                   Foreground="{DynamicResource AccentPrimary}"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Game Mode ──────────────────────────────────────────────── -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <ListBox x:Name="GamesList"
                             ItemsSource="{Binding Games}"
                             SelectedItem="{Binding SelectedGame}"
                             Style="{StaticResource GameListBoxStyle}"
                             Height="58"
                             Margin="0,0,0,6"
                             AllowDrop="True"
                             DragEnter="GamesList_DragEnter"
                             DragOver="GamesList_DragEnter"
                             Drop="GamesList_Drop"
                             ToolTip="{DynamicResource Str_Game_DropHint}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding ExecutablePath, Converter={StaticResource GameIconConv}}"
                                           Width="16" Height="16"
                                           Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="{DynamicResource Str_Game_DropHint}"
                               Foreground="{DynamicResource AppFgDim}"
                               FontSize="10"
                               Margin="2,0,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="66"/>
                            <ColumnDefinition Width="66"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  Content="{DynamicResource Str_Game_Mode}"
                                  IsChecked="{Binding GameModeEnabled}"
                                  Style="{StaticResource DarkCheckBoxStyle}"
                                  VerticalAlignment="Center"/>

                        <Button Grid.Column="2"
                                Content="{DynamicResource Str_Game_Del}"
                                Command="{Binding RemoveGameCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="28"
                                Margin="0,0,6,0"/>

                        <Button Grid.Column="3"
                                Content="{DynamicResource Str_Game_Add}"
                                Command="{Binding AddGameCommand}"
                                Style="{StaticResource DarkButtonStyle}"
                                Height="28"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Bottom Controls ───────────────────────────────────────── -->
            <Grid Margin="0,2,0,8">
                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal">

                    <Button Content="⚙"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            Width="36" Height="28"
                            FontSize="16"
                            Margin="0,0,8,0"
                            ToolTip="Settings"/>

                    <Button Content="{Binding TimerButtonLabel}"
                            Command="{Binding ToggleTimerResolutionCommand}"
                            Style="{StaticResource DarkButtonStyle}"
                            Width="94" Height="28"
                            Margin="0,0,8,0"
                            ToolTip="{Binding ActualTimerMs, StringFormat='Active: {0:F3} ms'}"/>

                    <Button Content="?"
                            Command="{Binding ShowAboutCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            Width="36" Height="28"
                            FontSize="15"/>
                </StackPanel>
            </Grid>

            <!-- ── Status Bar ─────────────────────────────────────────────── -->
            <Border BorderBrush="{DynamicResource SeparatorBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="2,6,2,2">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{DynamicResource AppFgDim}"/>
            </Border>

        </StackPanel>

        <!-- ── Dim overlay ──────────────────────────────────────────────────── -->
        <Border x:Name="DimOverlay"
                Panel.ZIndex="5"
                Background="{DynamicResource DimOverlayBrush}"
                Opacity="0"
                Visibility="Collapsed">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding Settings.CloseCommand}"/>
            </Border.InputBindings>
        </Border>

        <!-- ── Settings panel (slides in from right) ───────────────────────── -->
        <Border x:Name="SettingsPanelContainer"
                Panel.ZIndex="10"
                Width="270"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="{DynamicResource SurfaceBg}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1,0,0,0"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PanelTranslate" X="270"/>
            </Border.RenderTransform>
            <views:SettingsPanelView DataContext="{Binding Settings}"/>
        </Border>

        <!-- ── About overlay ───────────────────────────────────────────────── -->
        <Border x:Name="AboutOverlay"
                Panel.ZIndex="18"
                Background="{DynamicResource ModalOverlayBrush}"
                Visibility="{Binding IsAboutVisible, Converter={StaticResource BoolToVis}}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAboutCommand}"/>
            </Border.InputBindings>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface2Bg}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusLarge}"
                    Padding="22,18"
                    MaxWidth="380">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="⬤"
                                   FontSize="9"
                                   Foreground="{DynamicResource AccentPrimary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding AboutTitle}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppFg}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding AboutText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AppFgDim}"
                               FontSize="11"
                               FontFamily="Consolas"
                               Margin="0,0,0,16"/>

                    <Button Content="{Binding AboutClose}"
                            Command="{Binding CloseAboutCommand}"
                            Style="{StaticResource DarkButtonStyle}"
                            HorizontalAlignment="Right"
                            MinWidth="80" Height="30"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- ── Close confirmation overlay (above everything) ───────────────── -->
        <Border x:Name="CloseDialogOverlay"
                Panel.ZIndex="20"
                Background="{DynamicResource ModalOverlayBrush}"
                Visibility="Collapsed">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface2Bg}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusLarge}"
                    Padding="22,20"
                    MinWidth="290">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="⬤"
                                   FontSize="9"
                                   Foreground="{DynamicResource AccentPrimary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource Str_Close_Title}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppFg}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource Str_Close_Message}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AppFgDim}"
                               FontSize="12"
                               MaxWidth="260"
                               Margin="0,0,0,18"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                x:Name="CloseExitBtn"
                                Content="{DynamicResource Str_Close_Exit}"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="32"
                                Click="OnCloseExitClick"/>

                        <Button Grid.Column="2"
                                x:Name="CloseMinimizeBtn"
                                Content="{DynamicResource Str_Close_Minimize}"
                                Style="{StaticResource DarkButtonStyle}"
                                Height="32"
                                Click="OnCloseMinimizeClick"/>
                    </Grid>

                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
