<Window x:Class="StandbyAndTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:StandbyAndTimer.Views"
        xmlns:cards="clr-namespace:StandbyAndTimer.Views.Cards"
        xmlns:overlays="clr-namespace:StandbyAndTimer.Views.Overlays"
        Title="StandbyAndTimer"
        Width="540"
        Height="600"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource AppFg}"
        FontFamily="Segoe UI"
        FontSize="13" Icon="/app_icon.ico">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/Styles/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer container with a 1px border so the borderless window still has a visible edge -->
    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Background="{DynamicResource AppBg}">

        <!-- Root grid: title bar + main content + overlays -->
        <Grid x:Name="RootGrid" ClipToBounds="True">
            <Grid.RowDefinitions>
                <!-- Row 0 = title bar, locked to 36 px. Was Height="Auto" but
                     when the Settings panel opens, its RowSpan="2" +
                     VerticalAlignment="Stretch" content height was bleeding
                     into Row 0 and inflating the title bar by a few pixels —
                     the user saw the bar "grow upward" each time Settings
                     was toggled. A fixed row height makes the title bar
                     immune to whatever lives in the overlay layer. -->
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════════ TITLE BAR ═══════════════════ -->
            <cards:TitleBar Grid.Row="0"
                            MinimizeRequested="OnTitleBarMinimize"
                            CloseRequested="OnTitleBarClose"/>

            <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
            <StackPanel Grid.Row="1" Margin="14,12,14,10">
                <cards:TimerCard/>

                <!-- Memory Stats (left) + Standby Purge (right) side-by-side -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <cards:MemoryStatsCard  Grid.Column="0"/>
                    <cards:StandbyPurgeCard Grid.Column="2"/>
                </Grid>

                <cards:GameModeCard GameDropped="OnGameDropped"/>
                <cards:StatusBar/>
            </StackPanel>

            <!-- ═══════════════════ DIM OVERLAY ═══════════════════ -->
            <Border x:Name="DimOverlay"
                    Grid.Row="0" Grid.RowSpan="2"
                    Panel.ZIndex="5"
                    Background="{DynamicResource DimOverlayBrush}"
                    Opacity="0"
                    Visibility="Collapsed">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding Settings.CloseCommand}"/>
                </Border.InputBindings>
            </Border>

            <!-- ═══════════════════ SETTINGS PANEL (slides in from right) ═══════════════════ -->
            <Border x:Name="SettingsPanelContainer"
                    Grid.Row="0" Grid.RowSpan="2"
                    Panel.ZIndex="10"
                    Width="270"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource SurfaceBg}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="PanelTranslate" X="270"/>
                </Border.RenderTransform>
                <views:SettingsPanelView DataContext="{Binding Settings}"/>
            </Border>

            <!-- ═══════════════════ MODAL OVERLAYS ═══════════════════ -->
            <overlays:AboutOverlay  Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="18"/>
            <overlays:WizardOverlay Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="19"/>
            <overlays:CloseConfirmationOverlay x:Name="CloseDialog"
                                               Grid.Row="0" Grid.RowSpan="2"
                                               Panel.ZIndex="20"
                                               MinimizeRequested="OnCloseDialogMinimize"
                                               ExitRequested="OnCloseDialogExit"/>
        </Grid>
    </Border>
</Window>
