<Window x:Class="StandbyAndTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:StandbyAndTimer.Views"
        xmlns:conv="clr-namespace:StandbyAndTimer.Views.Converters"
        Title="StandbyAndTimer"
        Width="540"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource AppFg}"
        FontFamily="Segoe UI"
        FontSize="13" Icon="/app_icon.ico">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/Styles/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:GameIconConverter x:Key="GameIconConv"/>
            <conv:MbToGbConverter   x:Key="MbToGbConv"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer container with a 1px border so the borderless window still has a visible edge -->
    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Background="{DynamicResource AppBg}">

        <!-- Root grid: title bar + main content + overlays -->
        <Grid x:Name="RootGrid" ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════════ CUSTOM TITLE BAR ═══════════════════ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBg}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    Height="36">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: status dot + app name -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Margin="14,0,0,0"
                                VerticalAlignment="Center">
                        <Ellipse Width="9" Height="9"
                                 Fill="{DynamicResource SuccessColor}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,9,0"/>
                        <TextBlock Text="StandbyAndTimer"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppFg}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: admin badge + window controls -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">

                        <Border Style="{StaticResource SuccessBadgeStyle}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M5,0 L5,3 L9,3 L9,8 L1,8 L1,3 L5,3 M3,3 L3,1.5 A2,2 0 0 1 7,1.5 L7,3"
                                      Stroke="{DynamicResource SuccessColor}"
                                      StrokeThickness="1"
                                      Width="10" Height="9"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,5,0"/>
                                <TextBlock Text="{DynamicResource Str_TitleBar_Admin}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessColor}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Style="{StaticResource TitleBarIconButtonStyle}"
                                Content="⚙"
                                FontSize="14"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip="Settings"/>

                        <Button Style="{StaticResource TitleBarIconButtonStyle}"
                                Content="?"
                                FontSize="13"
                                Command="{Binding ShowAboutCommand}"
                                ToolTip="About"/>

                        <Button x:Name="MinimizeBtn"
                                Style="{StaticResource TitleBarIconButtonStyle}"
                                Content="—"
                                FontSize="11"
                                Click="OnMinimizeClick"
                                ToolTip="Minimize"/>

                        <Button x:Name="CloseBtn"
                                Style="{StaticResource TitleBarCloseButtonStyle}"
                                Content="✕"
                                FontSize="12"
                                Click="OnCloseClick"
                                ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
            <StackPanel Grid.Row="1" Margin="14,12,14,10">

                <!-- ── Hero: Timer Resolution ─────────────────────────────────── -->
                <Border Style="{StaticResource SectionBorderStyle}" Padding="18,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="{DynamicResource Str_Card_TimerTitle}"
                                       Style="{StaticResource SectionLabelStyle}"
                                       VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right"
                                    Style="{StaticResource SuccessBadgeStyle}"
                                    Visibility="{Binding TimerActive, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M5,0 L5,3 L9,3 L9,8 L1,8 L1,3 L5,3 M3,3 L3,1.5 A2,2 0 0 1 7,1.5 L7,3"
                                          Stroke="{DynamicResource SuccessColor}"
                                          StrokeThickness="1"
                                          Width="10" Height="9"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,5,0"/>
                                    <TextBlock Text="{DynamicResource Str_Card_TimerLocked}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SuccessColor}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActualTimerMs, StringFormat={}{0:F2}}"
                                           Style="{StaticResource HeroValueStyle}"/>
                                <TextBlock Text="ms"
                                           FontSize="18"
                                           FontWeight="Light"
                                           Foreground="{DynamicResource AppFgDim}"
                                           VerticalAlignment="Bottom"
                                           Margin="6,0,0,12"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="{Binding TimerButtonLabel}"
                                    Command="{Binding ToggleTimerResolutionCommand}"
                                    Style="{StaticResource DarkButtonStyle}"
                                    MinWidth="120" Height="38"
                                    VerticalAlignment="Center"
                                    FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Memory Stats (left) + Standby Purge (right) ──────────── -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Standby Memory KPI card -->
                    <Border Grid.Column="0"
                            Style="{StaticResource SectionBorderStyle}"
                            Padding="16,14"
                            Margin="0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_Card_StandbyTitle}"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StandbyRamMb, Converter={StaticResource MbToGbConv}}"
                                           Style="{StaticResource KpiValueStyle}"/>
                                <TextBlock Text="GB"
                                           FontSize="13"
                                           VerticalAlignment="Bottom"
                                           Margin="5,0,0,5"
                                           Foreground="{DynamicResource AppFgDim}"/>
                            </StackPanel>

                            <TextBlock Text="{DynamicResource Str_Card_StandbyClearable}"
                                       FontSize="10"
                                       Foreground="{DynamicResource AppFgDim}"
                                       Margin="0,2,0,0"/>

                            <Border BorderBrush="{DynamicResource SeparatorBrush}"
                                    BorderThickness="0,1,0,0"
                                    Margin="0,10,0,0"
                                    Padding="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Str_Memory_TotalShort}"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource AppFgDim}"/>
                                        <TextBlock Text="{Binding TotalRamMb, StringFormat={}{0} MB}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentPrimary}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{DynamicResource Str_Memory_FreeShort}"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource AppFgDim}"/>
                                        <TextBlock Text="{Binding FreeRamMb, StringFormat={}{0} MB}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessColor}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Standby Purge card -->
                    <Border Grid.Column="2"
                            Style="{StaticResource SectionBorderStyle}"
                            Padding="16,14"
                            Margin="0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource Str_Card_PurgeTitle}"
                                           Style="{StaticResource SectionLabelStyle}"/>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="×"
                                               Foreground="{DynamicResource AppFgDim}"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PurgeCount}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentPrimary}"
                                               Margin="2,0,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- AUTO PURGE master toggle — when off, both thresholds
                                 are ignored and no automatic purge ever fires. -->
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource Str_Card_AutoPurgeLabel}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppFgDim}"
                                           VerticalAlignment="Center"/>
                                <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding AutoPurgeEnabled}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center">
                                    <CheckBox.Content>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource Str_Card_GameModeOff}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AutoPurgeEnabled}" Value="True">
                                                            <Setter Property="Text" Value="{DynamicResource Str_Card_GameModeOn}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </CheckBox.Content>
                                </CheckBox>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="78"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{DynamicResource Str_Purge_StandbyLimitLabel}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppFgDim}"
                                           Margin="0,0,6,0"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding StandbyLimitMb, UpdateSourceTrigger=LostFocus}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Height="26" FontSize="12"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="78"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{DynamicResource Str_Purge_FreeLimitLabel}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppFgDim}"
                                           Margin="0,0,6,0"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding FreeLimitMb, UpdateSourceTrigger=LostFocus}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Height="26" FontSize="12"/>
                            </Grid>

                            <Button Content="{DynamicResource Str_Purge_Button}"
                                    Command="{Binding ManualPurgeCommand}"
                                    Style="{StaticResource DarkButtonStyle}"
                                    Height="32"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Game Mode (full width) ──────────────────────────────── -->
                <Border Style="{StaticResource SectionBorderStyle}" Padding="16,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="{DynamicResource Str_Card_GameModeTitle}"
                                       Style="{StaticResource SectionLabelStyle}"
                                       VerticalAlignment="Center"/>
                            <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding GameModeEnabled}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center">
                                <CheckBox.Content>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Str_Card_GameModeOff}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GameModeEnabled}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource Str_Card_GameModeOn}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </CheckBox.Content>
                            </CheckBox>
                        </Grid>

                        <TextBlock Text="{DynamicResource Str_Card_GameModeDesc}"
                                   FontSize="10"
                                   Foreground="{DynamicResource AppFgDim}"
                                   Margin="0,0,0,10"/>

                        <ListBox x:Name="GamesList"
                                 ItemsSource="{Binding Games}"
                                 SelectedItem="{Binding SelectedGame}"
                                 Style="{StaticResource GameListBoxStyle}"
                                 Height="60"
                                 Margin="0,0,0,8"
                                 AllowDrop="True"
                                 DragEnter="GamesList_DragEnter"
                                 DragOver="GamesList_DragEnter"
                                 Drop="GamesList_Drop"
                                 ToolTip="{DynamicResource Str_Game_DropHint}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding ExecutablePath, Converter={StaticResource GameIconConv}}"
                                               Width="16" Height="16"
                                               Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="66"/>
                                <ColumnDefinition Width="66"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource Str_Game_DropHint}"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AppFgDim}"/>
                            <Button Grid.Column="1"
                                    Content="{DynamicResource Str_Game_Del}"
                                    Command="{Binding RemoveGameCommand}"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Height="28"
                                    Margin="0,0,6,0"/>
                            <Button Grid.Column="2"
                                    Content="{DynamicResource Str_Game_Add}"
                                    Command="{Binding AddGameCommand}"
                                    Style="{StaticResource DarkButtonStyle}"
                                    Height="28"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Status Bar ─────────────────────────────────────────── -->
                <Border BorderBrush="{DynamicResource SeparatorBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="2,8,2,2"
                        Margin="0,2,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding StatusMessage}"
                                   FontSize="11"
                                   Foreground="{DynamicResource AppFgDim}"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1"
                                Style="{StaticResource MutedBadgeStyle}"
                                Padding="6,1">
                            <TextBlock Text="MVVM"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppFgDim}"/>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- ═══════════════════ DIM OVERLAY ═══════════════════ -->
            <Border x:Name="DimOverlay"
                    Grid.Row="0" Grid.RowSpan="2"
                    Panel.ZIndex="5"
                    Background="{DynamicResource DimOverlayBrush}"
                    Opacity="0"
                    Visibility="Collapsed">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding Settings.CloseCommand}"/>
                </Border.InputBindings>
            </Border>

            <!-- ═══════════════════ SETTINGS PANEL (slides in from right) ═══════════════════ -->
            <Border x:Name="SettingsPanelContainer"
                    Grid.Row="0" Grid.RowSpan="2"
                    Panel.ZIndex="10"
                    Width="270"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource SurfaceBg}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="PanelTranslate" X="270"/>
                </Border.RenderTransform>
                <views:SettingsPanelView DataContext="{Binding Settings}"/>
            </Border>

            <!-- ═══════════════════ ABOUT OVERLAY ═══════════════════ -->
            <Border x:Name="AboutOverlay"
                    Grid.Row="0" Grid.RowSpan="2"
                    Panel.ZIndex="18"
                    Background="{DynamicResource ModalOverlayBrush}"
                    Visibility="{Binding IsAboutVisible, Converter={StaticResource BoolToVis}}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAboutCommand}"/>
                </Border.InputBindings>
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusLarge}"
                        Padding="22,18"
                        MaxWidth="380">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="9" Height="9"
                                     Fill="{DynamicResource AccentPrimary}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding AboutTitle}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppFg}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{Binding AboutText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppFgDim}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   Margin="0,0,0,16"/>

                        <Button Content="{Binding AboutClose}"
                                Command="{Binding CloseAboutCommand}"
                                Style="{StaticResource DarkButtonStyle}"
                                HorizontalAlignment="Right"
                                MinWidth="80" Height="30"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ═══════════════════ FIRST-RUN WIZARD OVERLAY ═══════════════════
                 Shown once on the very first launch. Click-to-dismiss outside
                 the card is intentional — onboarding shouldn't trap a user
                 who already knows the app. -->
            <Border x:Name="WizardOverlay"
                    Grid.Row="0" Grid.RowSpan="2"
                    Panel.ZIndex="19"
                    Background="{DynamicResource ModalOverlayBrush}"
                    Visibility="{Binding IsWizardVisible, Converter={StaticResource BoolToVis}}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding DismissWizardCommand}"/>
                </Border.InputBindings>
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusLarge}"
                        Padding="24,20"
                        MaxWidth="420">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Ellipse Width="9" Height="9"
                                     Fill="{DynamicResource AccentPrimary}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding WizardTitle}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppFg}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{Binding WizardBody}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppFgDim}"
                                   FontSize="12"
                                   LineHeight="18"
                                   Margin="0,0,0,18"/>

                        <Button Content="{Binding WizardFinish}"
                                Command="{Binding DismissWizardCommand}"
                                Style="{StaticResource DarkButtonStyle}"
                                HorizontalAlignment="Right"
                                MinWidth="100" Height="32"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ═══════════════════ CLOSE CONFIRMATION OVERLAY (above everything) ═══════════════════ -->
            <Border x:Name="CloseDialogOverlay"
                    Grid.Row="0" Grid.RowSpan="2"
                    Panel.ZIndex="20"
                    Background="{DynamicResource ModalOverlayBrush}"
                    Visibility="Collapsed">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusLarge}"
                        Padding="22,20"
                        MinWidth="290">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="9" Height="9"
                                     Fill="{DynamicResource AccentPrimary}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Str_Close_Title}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppFg}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Str_Close_Message}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppFgDim}"
                                   FontSize="12"
                                   MaxWidth="260"
                                   Margin="0,0,0,18"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    x:Name="CloseExitBtn"
                                    Content="{DynamicResource Str_Close_Exit}"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Height="32"
                                    Click="OnCloseExitClick"/>

                            <Button Grid.Column="2"
                                    x:Name="CloseMinimizeBtn"
                                    Content="{DynamicResource Str_Close_Minimize}"
                                    Style="{StaticResource DarkButtonStyle}"
                                    Height="32"
                                    Click="OnCloseMinimizeClick"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>

        </Grid>
    </Border>
</Window>
